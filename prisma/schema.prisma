generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  ASSISTANT
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELED
  FOLLOW_UP
}

enum PaymentType {
  CREDIT_CARD
  DEBIT_CARD
  PIX
  CASH
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String?
  role         UserRole   @default(ASSISTANT)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  AuditLog     AuditLog[]
}

model Patient {
  id            String          @id @default(cuid())
  name          String
  cpf           String?         @unique
  whatsapp      String
  email         String?
  birthDate     DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  records       MedicalRecord[]
  treatmentPlans TreatmentPlan[]
  consents      ConsentLog[]
  stockMovements StockMovement[]
  loginTokens   LoginToken[]

  @@index([whatsapp])
}

model LoginToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  patientId String
  patient   Patient   @relation(fields: [patientId], references: [id])
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([patientId])
}

model TreatmentPlan {
  id                String          @id @default(cuid())
  patientId         String
  patient           Patient         @relation(fields: [patientId], references: [id])
  name              String
  totalSessions     Int             @default(1)
  completedSessions Int             @default(0)
  totalAmount       Decimal         @db.Decimal(10, 2)
  paymentStatus     String          @default("PENDING")
  records           MedicalRecord[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model MedicalRecord {
  id              String            @id @default(cuid())
  patientId       String
  patient         Patient           @relation(fields: [patientId], references: [id])
  treatmentPlanId String?
  treatmentPlan   TreatmentPlan?    @relation(fields: [treatmentPlanId], references: [id])
  procedureName   String
  anamneseData    Json
  photoUrl        String?
  annotations     Json?
  notes           String?
  status          AppointmentStatus @default(COMPLETED)
  stockMovements  StockMovement[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model InventoryItem {
  id           String          @id @default(cuid())
  name         String
  brand        String?
  description  String?
  unit         String          @default("un")
  minThreshold Int             @default(5)
  batches      InventoryBatch[]
  movements    StockMovement[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model InventoryBatch {
  id              String          @id @default(cuid())
  itemId          String
  item            InventoryItem   @relation(fields: [itemId], references: [id])
  lotNumber       String
  expiryDate      DateTime
  initialQuantity Int
  currentQuantity Int
  movements       StockMovement[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model StockMovement {
  id             String          @id @default(cuid())
  itemId         String
  item           InventoryItem   @relation(fields: [itemId], references: [id])
  batchId        String
  batch          InventoryBatch  @relation(fields: [batchId], references: [id])
  patientId      String?
  patient        Patient?        @relation(fields: [patientId], references: [id])
  recordId       String?
  record         MedicalRecord?  @relation(fields: [recordId], references: [id])
  quantityChange Int
  reason         String
  createdAt      DateTime        @default(now())
}

model ConsentLog {
  id          String   @id @default(cuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id])
  termVersion String
  ipAddress   String
  userAgent   String
  acceptedAt  DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String
  resourceId String?
  timestamp  DateTime @default(now())
  details    String?
}
